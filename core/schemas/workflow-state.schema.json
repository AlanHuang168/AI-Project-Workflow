{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Project Workflow State",
  "type": "object",
  "required": [
    "workflowVersion",
    "projectName",
    "currentStage",
    "completedStages",
    "blocked",
    "blockReason",
    "documents",
    "lastUpdatedAt"
  ],
  "properties": {
    "workflowVersion": { "type": "string" },
    "workflowProtocolVersion": { "type": "string" },
    "workflowStages": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      }
    },
    "projectName": { "type": "string" },
    "currentStage": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "completedStages": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      }
    },
    "blocked": { "type": "boolean" },
    "blockReason": { "type": "string" },
    "documents": {
      "type": "object",
      "required": ["prd", "arch", "sdd", "test", "review", "deploy", "retro"],
      "properties": {
        "prd": { "enum": ["missing", "draft", "complete", "skipped"] },
        "arch": { "enum": ["missing", "draft", "complete", "skipped"] },
        "sdd": { "enum": ["missing", "draft", "complete", "skipped"] },
        "test": { "enum": ["missing", "draft", "complete", "skipped"] },
        "review": { "enum": ["missing", "draft", "complete", "skipped"] },
        "deploy": { "enum": ["missing", "draft", "complete", "skipped"] },
        "retro": { "enum": ["missing", "draft", "complete", "skipped"] }
      },
      "additionalProperties": false
    },
    "skippedStages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stage", "reason", "approvedByUser"],
        "properties": {
          "stage": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "reason": { "type": "string" },
          "approvedByUser": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "lastUpdatedAt": {
      "type": "string",
      "description": "ISO 8601 timestamp"
    }
  },
  "additionalProperties": false
}
